#!/usr/bin/env bash
# claude-bridge — watches a private rivendell channel and forwards each message
# to Claude Code. While a job runs the originating message wears a 👍
# reaction; on completion the reaction is removed and the result is posted as a
# threaded reply to the originating message — which on its own pings the
# requester (the server treats replying to someone as a ping), so the bridge
# never has to name them. Also responds to DMs sent directly to the bot user
# (low-effort, read-only).
#
# Concurrency: each request runs as a background job, so the poll loop never
# blocks. Different channels run in parallel — in particular you can DM the bot
# a question while a long job is still running in the main channel. Within a
# single channel only one job runs at a time; a second request to a busy channel
# is politely declined (resend it once the first finishes).
#
# Interrupting: send "!stop" (also "!cancel" / "!interrupt") in a channel or DM
# to kill the job currently running there. The bot confirms with a reply, and
# the in-progress reaction it left behind is cleared.
#
# Usage stats: send "!usage" to get a markdown table of Claude Code token usage
# and costs aggregated across all sessions.
#
# Required env:
#   RIVENDELL_URL        Base URL of your rivendell instance  (e.g. http://localhost:8080)
#   RIVENDELL_BOT_TOKEN  Bearer token from POST /api/admin/bot-tokens
#
# Optional env:
#   RIVENDELL_CLAUDE_CHANNEL         Channel name to watch (default: claude)
#   RIVENDELL_REPO_DIR               Repo directory Claude runs in (default: parent of this script)
#   RIVENDELL_POLL_INTERVAL          Seconds between polls (default: 3)
#   RIVENDELL_STATE_DIR              Where to persist the last-seen message id (default: /tmp)
#   RIVENDELL_WORKING_EMOJI          "In progress" reaction (default: 👍 — a literal
#                                    Unicode emoji, which every instance accepts with no
#                                    setup). To override with a CUSTOM emoji, give the bare
#                                    shortcode, no colons (e.g. working, not :working:) — and
#                                    register it on the instance first, or the reactions API
#                                    rejects it with 400 (silently swallowed here).
#   RIVENDELL_RELEASE_UPDATE_CHANNEL Channel name (no # prefix) to post release notes in
#                                    whenever a job produces a user-visible change (new
#                                    feature, bugfix, breaking change). Must be a public
#                                    channel or one the bot is a member of. When unset,
#                                    release note posting is disabled.
#
# Setup checklist:
#   1. Create a bot user via the admin panel (e.g. username "claude-bot").
#   2. POST /api/admin/bot-tokens {"name":"claude-bridge","user_id":<bot-user-id>}
#      Save the returned "token" — it won't be shown again.
#   3. Create a private channel named "claude" and add the bot user as a member.
#      Also add whichever human users you want to be able to send requests.
#   4. Export RIVENDELL_URL and RIVENDELL_BOT_TOKEN, then run this script.
#      A systemd unit or a persistent tmux session both work fine.

set -euo pipefail

RIVENDELL_URL="${RIVENDELL_URL:-http://localhost:8080}"
RIVENDELL_BOT_TOKEN="${RIVENDELL_BOT_TOKEN:?RIVENDELL_BOT_TOKEN not set}"
CHANNEL_NAME="${RIVENDELL_CLAUDE_CHANNEL:-claude}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="${RIVENDELL_REPO_DIR:-$(cd "$SCRIPT_DIR/.." && pwd)}"
POLL_INTERVAL="${RIVENDELL_POLL_INTERVAL:-3}"
STATE_DIR="${RIVENDELL_STATE_DIR:-/tmp}"
STATE_FILE="$STATE_DIR/rivendell-bridge-lastid"
JOBS_DIR="$STATE_DIR/rivendell-bridge-jobs"  # one file per channel with a live job: "<pid> <msg_id>"
WORKING_EMOJI="${RIVENDELL_WORKING_EMOJI:-👍}"  # "in progress" reaction (literal Unicode emoji — ships everywhere; see above)
RELEASE_UPDATE_CHANNEL="${RIVENDELL_RELEASE_UPDATE_CHANNEL:-}"
MAX_RESPONSE=3800  # chars per chunk; leaves headroom under rivendell's default 4096-byte limit

# Standing instructions prepended to every request before it reaches Claude.
# These ride on the message itself so they apply regardless of what the project
# memory does or doesn't retain — the test-database URL in particular has been
# chronically forgotten. Keep this in sync with the conventions in CLAUDE.md.
BRIDGE_PREAMBLE='Project standing instructions (injected by claude-bridge — always apply, do not skip):

1. Running tests: the Go integration tests are gated on TEST_DATABASE_URL and
   SILENTLY SKIP without it. You MUST run the suite as:
       make test TEST_DATABASE_URL='\''postgres://chat:chat_dev_pw@localhost:55432/chat_test?sslmode=disable'\''
   Never report tests as run/passing/green unless you ran them with that URL set.

2. Committing: when the work is complete and the full suite above is green, commit
   to the develop branch (a develop commit auto-deploys to the test env). Bump the
   patch Version constant in internal/config/config.go in that same commit, unless
   the change is helper-script/docs-only and does not affect the built binary.
   Do not sweep in unrelated uncommitted working-tree changes you did not author.

3. Changelog: for user-visible changes (new feature, bugfix, breaking change),
   update CHANGELOG.md in the same commit: rename the existing `## [Unreleased]`
   heading to `## [new-version] - YYYY-MM-DD` (matching the version just bumped
   and today'\''s date), add the change as a `### Added`, `### Fixed`, or
   `### Changed` bullet under it, and insert a fresh `## [Unreleased]\n` line
   above it. Internal-only changes (refactor, docs, tests, tooling, scripts) do
   not warrant a changelog entry — leave CHANGELOG.md untouched.

4. Release notes signal: at the very end of your response, if you made a
   user-visible change, append exactly one line in this format:
       RELEASE_NOTE: <plain-language one-line summary of the change>
   Omit this line entirely for internal-only changes. Do not add any label,
   explanation, or blank line after it — the bridge strips it before showing
   the response to the requester and uses it to post a release notification.

----- user request follows -----
'

# ---------------------------------------------------------------------------
# Dependency check

for cmd in curl jq claude pgrep; do
    command -v "$cmd" >/dev/null 2>&1 || { echo "error: $cmd is required" >&2; exit 1; }
done

# ---------------------------------------------------------------------------
# Helpers

api() {
    local method="$1" path="$2"; shift 2
    curl -sf -X "$method" \
        -H "Authorization: Bearer $RIVENDELL_BOT_TOKEN" \
        -H "Content-Type: application/json" \
        -H "User-Agent: rivendell-claude-bridge/1.0" \
        "$RIVENDELL_URL/api$path" "$@"
}

post_msg() {
    api POST "/channels/$1/messages" --data "$(jq -n --arg c "$2" '{content:$c}')"
}

# reply_msg <channel_id> <reply_to_id> <content> — post a threaded reply.
reply_msg() {
    api POST "/channels/$1/messages" \
        --data "$(jq -n --arg c "$3" --argjson r "$2" '{content:$c, reply_to_id:$r}')"
}

# react / unreact <message_id> <emoji> — add/remove a reaction. Best-effort: a
# failure (e.g. unregistered emoji, since-deleted message) must never derail the
# job, so errors are swallowed. Removing a reaction that isn't there is a harmless
# no-op, which keeps cleanup safe even if the add failed.
react() {
    api PUT "/messages/$1/reactions" \
        --data "$(jq -n --arg e "$2" '{emoji:$e}')" >/dev/null 2>&1 || true
}
unreact() {
    api DELETE "/messages/$1/reactions" \
        --data "$(jq -n --arg e "$2" '{emoji:$e}')" >/dev/null 2>&1 || true
}

# pin_msg <message_id> — pin a message. Best-effort; a failure must not derail the job.
pin_msg() {
    api PUT "/messages/$1/pin" >/dev/null 2>&1 || true
}

set_status() {
    api PUT /me/status --data "$(jq -n --arg s "$1" '{status:$s}')" >/dev/null 2>&1 || true
}

set_status_text() {
    api PATCH /me --data "$(jq -n --arg t "$1" '{status_text:$t}')" >/dev/null 2>&1 || true
}

# post_reply_chunks <channel_id> <msg_id> <text>
# Posts <text> as one or more threaded replies, each at most MAX_RESPONSE chars.
# Prefers to split on newlines; falls back to hard char splits for lines that
# are themselves longer than MAX_RESPONSE.
post_reply_chunks() {
    local channel_id="$1" msg_id="$2" text="$3"
    [ -z "$text" ] && return
    local chunk="" line candidate
    while IFS= read -r line || [ -n "$line" ]; do
        if [ -z "$chunk" ]; then
            candidate="$line"
        else
            candidate="${chunk}
${line}"
        fi
        if [ "${#candidate}" -gt "$MAX_RESPONSE" ]; then
            if [ -n "$chunk" ]; then
                reply_msg "$channel_id" "$msg_id" "$chunk" >/dev/null 2>&1 \
                    || post_msg "$channel_id" "$chunk" >/dev/null 2>&1 || true
                chunk=""
            fi
            while [ "${#line}" -gt "$MAX_RESPONSE" ]; do
                reply_msg "$channel_id" "$msg_id" "${line:0:$MAX_RESPONSE}" >/dev/null 2>&1 \
                    || post_msg "$channel_id" "${line:0:$MAX_RESPONSE}" >/dev/null 2>&1 || true
                line="${line:$MAX_RESPONSE}"
            done
            chunk="$line"
        else
            chunk="$candidate"
        fi
    done < <(printf '%s' "$text")
    if [ -n "$chunk" ]; then
        reply_msg "$channel_id" "$msg_id" "$chunk" >/dev/null 2>&1 \
            || post_msg "$channel_id" "$chunk" >/dev/null 2>&1 || true
    fi
}

# fetch_message_images <content> <outdir>
# Downloads any /api/blobs/<hash> images referenced in the message content into
# <outdir>, and echoes a newline-separated list of the local file paths written.
# Image attachments arrive in the message as `![image](/api/blobs/<sha256>)`
# markdown (see the upload UX in CLAUDE.md); the blob endpoint is session-gated
# but accepts our Bearer token. Each blob is named by its hash plus an extension
# derived from the served Content-Type so Claude's Read tool can view it.
fetch_message_images() {
    local content="$1" outdir="$2"
    local -a hashes
    mapfile -t hashes < <(grep -oE 'blobs/[0-9a-f]{64}' <<<"$content" \
        | sed 's#blobs/##' | sort -u)
    [ "${#hashes[@]}" -eq 0 ] && return 0

    local h ct ext outfile
    for h in "${hashes[@]}"; do
        outfile="$outdir/$h"
        ct=$(curl -sf -X GET \
            -H "Authorization: Bearer $RIVENDELL_BOT_TOKEN" \
            -H "User-Agent: rivendell-claude-bridge/1.0" \
            -o "$outfile" -w '%{content_type}' \
            "$RIVENDELL_URL/api/blobs/$h" 2>/dev/null) || continue
        case "$ct" in
            image/png)  ext=png ;;
            image/jpeg) ext=jpg ;;
            image/webp) ext=webp ;;
            image/gif)  ext=gif ;;
            *)          ext=img ;;   # unrecognised type — pass it through anyway
        esac
        mv "$outfile" "$outfile.$ext" 2>/dev/null || continue
        printf '%s\n' "$outfile.$ext"
    done
}

# ---------------------------------------------------------------------------
# Concurrency / interrupt helpers
#
# Each in-flight request is a background subshell. Per channel we keep one
# registry file ($JOBS_DIR/<channel_id>) holding "<pid> <msg_id>": the pid lets
# us observe and kill the job, the msg_id lets us clear its in-progress reaction
# if we kill it. Different channels run concurrently; a channel runs at most one
# job at a time.

# is_stop_command <content> — true if the message is an interrupt command.
is_stop_command() {
    local c
    c=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')
    case "$c" in
        '!stop'|'!cancel'|'!interrupt') return 0 ;;
    esac
    return 1
}

# is_usage_command <content> — true if the message is a usage stats request.
is_usage_command() {
    local c
    c=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')
    [ "$c" = "!usage" ]
}

# is_busy <channel_id> — true if a live job is registered for the channel. A
# registry entry whose process is gone is stale; reap it and report not-busy.
is_busy() {
    local f="$JOBS_DIR/$1" pid
    [ -f "$f" ] || return 1
    pid=$(cut -d' ' -f1 "$f" 2>/dev/null)
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
        return 0
    fi
    rm -f "$f"
    return 1
}

# active_job_count — number of channels with a live job, reaping stale entries.
active_job_count() {
    local n=0 f pid
    for f in "$JOBS_DIR"/*; do
        [ -e "$f" ] || continue
        pid=$(cut -d' ' -f1 "$f" 2>/dev/null)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            n=$((n + 1))
        else
            rm -f "$f"
        fi
    done
    printf '%s' "$n"
}

# kill_tree <pid> — TERM a process and all its descendants, leaves first, so the
# claude child dies before the subshell that's waiting on it (which would
# otherwise be orphaned). pgrep walks the tree without job control.
kill_tree() {
    local pid="$1" child
    while IFS= read -r child; do
        [ -n "$child" ] && kill_tree "$child"
    done < <(pgrep -P "$pid" 2>/dev/null || true)
    kill -TERM "$pid" 2>/dev/null || true
}

# interrupt_channel <channel_id> — kill the channel's running job. Returns 0 if
# something was actually killed, 1 if nothing was running.
interrupt_channel() {
    local f="$JOBS_DIR/$1" line pid msg_id
    [ -f "$f" ] || return 1
    line=$(cat "$f" 2>/dev/null) || { rm -f "$f"; return 1; }
    pid=${line%% *}
    msg_id=${line##* }
    if [ -z "$pid" ] || ! kill -0 "$pid" 2>/dev/null; then
        rm -f "$f"
        return 1
    fi
    kill_tree "$pid"
    rm -f "$f"
    # The killed job can't run its own cleanup, so drop its 👍 reaction here.
    [ -n "$msg_id" ] && [ "$msg_id" != "$pid" ] && unreact "$msg_id" "$WORKING_EMOJI"
    return 0
}

# run_claude_job <channel_id> <mode> <msg_id> <content>
# The actual work, run inside a background subshell (see handle_channel). On a
# clean finish it drops its own registry entry; if interrupted, interrupt_channel
# has already removed the entry and cleared the reaction.
run_claude_job() {
    local channel_id="$1" mode="$2" msg_id="$3" content="$4"

    # Restore default INT/TERM so an interrupt's SIGTERM actually kills this job —
    # the parent traps those signals for graceful shutdown and a subshell inherits
    # the trap, which would otherwise swallow the kill.
    trap - INT TERM
    # On a clean exit, remove our registry entry, but only if it's still ours (an
    # interrupt may have removed it and a newer job replaced it).
    trap '[ "$(cut -d" " -f1 "$JOBS_DIR/$channel_id" 2>/dev/null)" = "$BASHPID" ] && rm -f "$JOBS_DIR/$channel_id"' EXIT

    # Signal "work in progress" by reacting to the user's own message.
    react "$msg_id" "$WORKING_EMOJI"

    # Pull down any attached images so Claude can actually see them (the blob
    # markdown is a session-gated server URL, useless to Claude on its own).
    local img_dir img_paths prompt_content
    img_dir=$(mktemp -d)
    img_paths=$(fetch_message_images "$content" "$img_dir")
    prompt_content="$content"
    local -a img_args=()
    if [ -n "$img_paths" ]; then
        prompt_content="$content

[The user attached image file(s). Read each of these local paths with the Read tool to view them:]
$img_paths"
        img_args=(--add-dir "$img_dir")
    fi

    local claude_exit=0 claude_out
    if [ "$mode" = "dm" ]; then
        # DM mode: low-effort, no file write tools. -- terminates flag parsing so
        # $prompt_content isn't consumed as a tool name by --disallowed-tools.
        claude_out=$(cd "$REPO_DIR" && claude --print --effort low \
            --disallowed-tools "Edit,Write,Bash" "${img_args[@]}" -- \
            "$prompt_content" 2>&1) || claude_exit=$?
    else
        # -- terminates flag parsing so the prompt isn't swallowed by --add-dir.
        claude_out=$(cd "$REPO_DIR" && claude --print "${img_args[@]}" -- \
            "$BRIDGE_PREAMBLE$prompt_content" 2>&1) || claude_exit=$?
    fi
    rm -rf "$img_dir"

    # Extract any RELEASE_NOTE sentinel before building the user-facing reply.
    # Claude appends exactly one line "RELEASE_NOTE: <text>" for user-visible changes.
    local release_note=""
    release_note=$(grep '^RELEASE_NOTE: ' <<<"$claude_out" | tail -1 | cut -c15-) || true
    local claude_out_display
    claude_out_display=$(grep -v '^RELEASE_NOTE: ' <<<"$claude_out") || true

    local reply_text
    if [ "$claude_exit" -eq 0 ]; then
        reply_text="${claude_out_display:-✅ Done.}"
    else
        if [ -n "$claude_out_display" ]; then
            reply_text="❌ Error (exit $claude_exit).

$claude_out_display"
        else
            reply_text="❌ Error (exit $claude_exit)."
        fi
    fi

    # Post the result as one or more threaded replies, chunked if the output is
    # long. Each chunk falls back to a plain post if the reply target is gone.
    post_reply_chunks "$channel_id" "$msg_id" "$reply_text"
    unreact "$msg_id" "$WORKING_EMOJI"

    # Post release note to the configured channel if this was a user-visible change,
    # then pin it so it's easy to find in the release history.
    if [ "$claude_exit" -eq 0 ] && [ -n "$release_note" ] && [ -n "${RELEASE_UPDATE_CHANNEL_ID:-}" ]; then
        local version=""
        version=$(grep -oP '(?<=const Version = ")[^"]+' \
            "$REPO_DIR/internal/config/config.go" 2>/dev/null || true)
        local note_msg
        if [ -n "$version" ]; then
            note_msg="📦 **v${version}** — ${release_note}"
        else
            note_msg="📦 ${release_note}"
        fi
        local note_resp note_id
        note_resp=$(post_msg "$RELEASE_UPDATE_CHANNEL_ID" "$note_msg" 2>/dev/null) || true
        note_id=$(jq -r '.id // empty' <<<"$note_resp" 2>/dev/null) || true
        [ -n "$note_id" ] && pin_msg "$note_id"
    fi
}

# ---------------------------------------------------------------------------
# Startup

echo "rivendell-claude-bridge starting"
echo "  url:      $RIVENDELL_URL"
echo "  channel:  #$CHANNEL_NAME"
echo "  repo:     $REPO_DIR"

ME=$(api GET /me)
BOT_ID=$(jq -r '.id'           <<<"$ME")
BOT_NAME=$(jq -r '.display_name' <<<"$ME")
echo "  bot:      $BOT_NAME (id $BOT_ID)"

# Find the channel the bot is a member of.
CHANNEL_ID=$(api GET /channels \
    | jq -r --arg n "$CHANNEL_NAME" '.[] | select(.name == $n) | .id')
if [ -z "$CHANNEL_ID" ]; then
    cat >&2 <<EOF
error: channel #$CHANNEL_NAME not found.
  Create a private channel named "$CHANNEL_NAME" and add the bot user as a member,
  then restart this bridge.
EOF
    exit 1
fi
echo "  channel id: $CHANNEL_ID"

# Resolve the optional release-notes channel.
RELEASE_UPDATE_CHANNEL_ID=""
if [ -n "$RELEASE_UPDATE_CHANNEL" ]; then
    RELEASE_UPDATE_CHANNEL_ID=$(api GET /channels \
        | jq -r --arg n "$RELEASE_UPDATE_CHANNEL" '.[] | select(.name == $n) | .id' 2>/dev/null || true)
    if [ -z "$RELEASE_UPDATE_CHANNEL_ID" ]; then
        echo "  warn: release channel #$RELEASE_UPDATE_CHANNEL not found or bot has no access — release notes disabled"
    else
        echo "  release notes:  #$RELEASE_UPDATE_CHANNEL (id $RELEASE_UPDATE_CHANNEL_ID)"
    fi
fi

# Seed the last-seen cursor so we don't replay history on first start.
if [ ! -f "$STATE_FILE" ]; then
    SEED_ID=$(api GET "/channels/$CHANNEL_ID/messages?limit=1" \
        | jq -r 'if length > 0 then .[0].id else 0 end')
    printf '%s' "$SEED_ID" > "$STATE_FILE"
    echo "  seeded at message id $SEED_ID"
fi

# Fresh job registry — any entries left over from a previous run are stale (their
# pids may even have been reused by unrelated processes).
mkdir -p "$JOBS_DIR"
rm -f "$JOBS_DIR"/* 2>/dev/null || true

echo "polling every ${POLL_INTERVAL}s — ready (DM mode: enabled, parallel; interrupt with !stop)"
echo ""

# Signal readiness via the bot's status.
set_status "online"
set_status_text "operational — waiting"

# ---------------------------------------------------------------------------
# Main loop

SHUTDOWN=0

do_cleanup() {
    # Let any in-flight jobs finish rather than sever work mid-edit. Send a
    # "!stop" first (or signal the bridge a second time) if you need a faster exit.
    local n; n=$(active_job_count)
    if [ "$n" -gt 0 ]; then
        echo "bridge: waiting for $n in-flight job(s) to finish…"
        wait
    fi
    rm -rf "$JOBS_DIR"
    set_status "offline"
    set_status_text "offline"
    echo "bridge stopped"
    exit 0
}

on_shutdown() {
    SHUTDOWN=1
    echo "bridge: shutdown requested — finishing in-flight work before exit…" >&2
}
trap on_shutdown INT TERM

# handle_channel <channel_id> <mode>
# mode = "normal"  → full Claude in $REPO_DIR with BRIDGE_PREAMBLE
# mode = "dm"      → low-effort Claude in $REPO_DIR, write tools disallowed, no preamble
#
# Dispatches each request as a background job (run_claude_job) so the poll loop
# never blocks: different channels run concurrently, but a channel runs at most
# one job at a time. Messages are always consumed in id order, so the cursor
# advances contiguously and nothing is lost. A "!stop" command interrupts the
# channel's running job and is honored even while it's busy.
handle_channel() {
    local channel_id="$1"
    local mode="$2"
    local state_file

    if [ "$mode" = "dm" ]; then
        state_file="$STATE_DIR/rivendell-bridge-dm-$channel_id"
    else
        state_file="$STATE_FILE"
    fi

    # Seed the cursor on first encounter.
    if [ ! -f "$state_file" ]; then
        local seed_id
        seed_id=$(api GET "/channels/$channel_id/messages?limit=1" 2>/dev/null \
            | jq -r 'if length > 0 then .[0].id else 0 end' 2>/dev/null) || return
        printf '%s' "$seed_id" > "$state_file"
        return
    fi

    local last_id
    last_id=$(cat "$state_file")

    local tmp
    tmp=$(mktemp)
    api GET "/channels/$channel_id/messages?limit=20" 2>/dev/null \
        | jq -c \
            --argjson last "$last_id" \
            --argjson bot  "$BOT_ID" \
            '[.[] | select(.id > $last and .user_id != $bot and .deleted_at == null)]
             | reverse | .[]' \
        > "$tmp" 2>/dev/null || { rm -f "$tmp"; return; }

    while IFS= read -r msg && [ -n "$msg" ]; do
        local msg_id content user_id
        msg_id=$(  jq -r '.id'      <<<"$msg")
        content=$( jq -r '.content' <<<"$msg")
        user_id=$( jq -r '.user_id' <<<"$msg")

        # Consume in id order so the cursor only ever advances contiguously.
        printf '%s' "$msg_id" > "$state_file"

        # Interrupt command — kill this channel's running job (honored even while
        # busy). The reply pings the requester.
        if is_stop_command "$content"; then
            printf '[%s msg %s user %s] stop command\n' "$mode" "$msg_id" "$user_id"
            if interrupt_channel "$channel_id"; then
                reply_msg "$channel_id" "$msg_id" "🛑 Interrupted the running job." >/dev/null 2>&1 || true
            else
                reply_msg "$channel_id" "$msg_id" "Nothing is currently running here to interrupt." >/dev/null 2>&1 || true
            fi
            continue
        fi

        # Usage command — parse Claude Code's JSONL conversation files directly and
        # reply with a markdown table. Runs synchronously (fast, read-only) so it
        # works even while a job is in progress and doesn't occupy the channel job slot.
        if is_usage_command "$content"; then
            printf '[%s msg %s user %s] usage command\n' "$mode" "$msg_id" "$user_id"
            react "$msg_id" "$WORKING_EMOJI"
            local usage_out
            usage_out=$(python3 - "$HOME/.claude/projects" <<'PYEOF'
import json, os, sys, glob, collections

projects_dir = sys.argv[1]
pattern = os.path.join(projects_dir, "*", "*.jsonl")

# input, output, cache_write, cache_read token counts
totals = collections.defaultdict(lambda: [0, 0, 0, 0])

for path in glob.glob(pattern):
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if obj.get("type") != "assistant":
                    continue
                msg = obj.get("message", {})
                model = msg.get("model", "")
                if not model:
                    continue
                usage = msg.get("usage", {})
                t = totals[model]
                t[0] += usage.get("input_tokens", 0)
                t[1] += usage.get("output_tokens", 0)
                t[2] += usage.get("cache_creation_input_tokens", 0)
                t[3] += usage.get("cache_read_input_tokens", 0)
    except OSError:
        pass

if not totals:
    print("No usage data found.")
    sys.exit(0)

# Approximate pricing per million tokens: (input, output, cache_write, cache_read)
PRICING = {
    "claude-opus-4":    (15.00, 75.00, 18.75, 1.50),
    "claude-opus-3-5":  (15.00, 75.00, 18.75, 1.50),
    "claude-sonnet-4":  ( 3.00, 15.00,  3.75, 0.30),
    "claude-sonnet-3-5":( 3.00, 15.00,  3.75, 0.30),
    "claude-haiku-4":   ( 0.80,  4.00,  1.00, 0.08),
    "claude-haiku-3-5": ( 0.80,  4.00,  1.00, 0.08),
}

def get_price(model):
    for k, v in PRICING.items():
        if k in model:
            return v
    return (3.00, 15.00, 3.75, 0.30)

rows = []
for model, (inp, out, cw, cr) in sorted(totals.items()):
    pin, pout, pcw, pcr = get_price(model)
    cost = (inp * pin + out * pout + cw * pcw + cr * pcr) / 1_000_000
    short = model.replace("claude-", "")
    rows.append((short, inp, out, cw, cr, cost))

print("| Model | Input | Output | Cache Write | Cache Read | Cost (USD) |")
print("|-------|------:|-------:|------------:|-----------:|-----------:|")
for short, inp, out, cw, cr, cost in rows:
    print(f"| {short} | {inp:,} | {out:,} | {cw:,} | {cr:,} | ${cost:.2f} |")

# Totals row
ti = sum(r[1] for r in rows)
to = sum(r[2] for r in rows)
tc = sum(r[3] for r in rows)
tr = sum(r[4] for r in rows)
tt = sum(r[5] for r in rows)
print(f"| **Total** | **{ti:,}** | **{to:,}** | **{tc:,}** | **{tr:,}** | **${tt:.2f}** |")
PYEOF
            ) || usage_out=""
            [ -z "$usage_out" ] && usage_out="No usage data available."
            reply_msg "$channel_id" "$msg_id" "$usage_out" >/dev/null 2>&1 || true
            unreact "$msg_id" "$WORKING_EMOJI"
            continue
        fi

        # One job per channel: politely decline a new request while this channel is
        # busy, rather than running two clobbering jobs. (Different channels — e.g.
        # a DM while the main channel works — still run in parallel.)
        if is_busy "$channel_id"; then
            printf '[%s msg %s user %s] busy — declined\n' "$mode" "$msg_id" "$user_id"
            reply_msg "$channel_id" "$msg_id" "⏳ I'm still working on a previous request in here. Send \`!stop\` to cancel it, or resend this once it's done." >/dev/null 2>&1 || true
            continue
        fi

        printf '[%s msg %s user %s] %s\n' "$mode" "$msg_id" "$user_id" "${content:0:100}"

        # Dispatch the work as a background job and register it so it can be
        # observed (is_busy) and interrupted (interrupt_channel). $! inside the
        # parent equals $BASHPID inside the subshell, so the job's own cleanup can
        # match this entry. The channel is now busy: any further work message this
        # cycle hits the is_busy branch above.
        run_claude_job "$channel_id" "$mode" "$msg_id" "$content" &
        local pid=$!
        printf '%s %s\n' "$pid" "$msg_id" > "$JOBS_DIR/$channel_id"

    done < "$tmp"
    rm -f "$tmp"
}

# Reflect the live job count in the bot's status text, but only PATCH when it
# changes (the loop runs every few seconds).
LAST_STATUS=""
update_status() {
    local n msg
    n=$(active_job_count)
    if [ "$n" -gt 0 ]; then
        msg="operational — $n job(s) running"
    else
        msg="operational — idle"
    fi
    if [ "$msg" != "$LAST_STATUS" ]; then
        set_status_text "$msg"
        set_status "online"
        LAST_STATUS="$msg"
    fi
}

while true; do
    sleep "$POLL_INTERVAL" || true   # interrupted sleep (on signal) must not trigger errexit
    [ "$SHUTDOWN" -eq 1 ] && do_cleanup

    # Main claude channel — full access. Dispatch is non-blocking.
    handle_channel "$CHANNEL_ID" "normal"
    [ "$SHUTDOWN" -eq 1 ] && do_cleanup

    # DM channels — discover dynamically each cycle, handle in low-effort mode.
    # These dispatch in parallel with each other and with the main channel, so a
    # DM question is answered even while a long job is still running.
    while IFS= read -r dm_id; do
        [ -n "$dm_id" ] && handle_channel "$dm_id" "dm"
    done < <(api GET /channels 2>/dev/null \
        | jq -r '[.[] | select(.is_dm == true)] | .[].id' 2>/dev/null || true)

    update_status
done
