#!/usr/bin/env bash
# claude-bridge — watches a private Rivendell channel and forwards each message
# to Claude Code, posting the result back as an edit of the "working…" placeholder.
# Also responds to DMs sent directly to the bot user (low-effort, read-only).
#
# Required env:
#   RIVENDELL_URL        Base URL of your Rivendell instance  (e.g. http://localhost:8080)
#   RIVENDELL_BOT_TOKEN  Bearer token from POST /api/admin/bot-tokens
#
# Optional env:
#   RIVENDELL_CLAUDE_CHANNEL  Channel name to watch (default: claude)
#   RIVENDELL_REPO_DIR        Repo directory Claude runs in (default: parent of this script)
#   RIVENDELL_POLL_INTERVAL   Seconds between polls (default: 3)
#   RIVENDELL_STATE_DIR       Where to persist the last-seen message id (default: /tmp)
#
# Setup checklist:
#   1. Create a bot user via the admin panel (e.g. username "claude-bot").
#   2. POST /api/admin/bot-tokens {"name":"claude-bridge","user_id":<bot-user-id>}
#      Save the returned "token" — it won't be shown again.
#   3. Create a private channel named "claude" and add the bot user as a member.
#      Also add whichever human users you want to be able to send requests.
#   4. Export RIVENDELL_URL and RIVENDELL_BOT_TOKEN, then run this script.
#      A systemd unit or a persistent tmux session both work fine.

set -euo pipefail

RIVENDELL_URL="${RIVENDELL_URL:-http://localhost:8080}"
RIVENDELL_BOT_TOKEN="${RIVENDELL_BOT_TOKEN:?RIVENDELL_BOT_TOKEN not set}"
CHANNEL_NAME="${RIVENDELL_CLAUDE_CHANNEL:-claude}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="${RIVENDELL_REPO_DIR:-$(cd "$SCRIPT_DIR/.." && pwd)}"
POLL_INTERVAL="${RIVENDELL_POLL_INTERVAL:-3}"
STATE_DIR="${RIVENDELL_STATE_DIR:-/tmp}"
STATE_FILE="$STATE_DIR/rivendell-bridge-lastid"
MAX_RESPONSE=3800  # chars; leaves headroom under Rivendell's default 4096-byte limit

# Standing instructions prepended to every request before it reaches Claude.
# These ride on the message itself so they apply regardless of what the project
# memory does or doesn't retain — the test-database URL in particular has been
# chronically forgotten. Keep this in sync with the conventions in CLAUDE.md.
BRIDGE_PREAMBLE='Project standing instructions (injected by claude-bridge — always apply, do not skip):

1. Running tests: the Go integration tests are gated on TEST_DATABASE_URL and
   SILENTLY SKIP without it. You MUST run the suite as:
       make test TEST_DATABASE_URL='\''postgres://chat:chat_dev_pw@localhost:55432/chat_test?sslmode=disable'\''
   Never report tests as run/passing/green unless you ran them with that URL set.

2. Committing: when the work is complete and the full suite above is green, commit
   to the develop branch (a develop commit auto-deploys to the test env). Bump the
   patch Version constant in internal/config/config.go in that same commit, unless
   the change is helper-script/docs-only and does not affect the built binary.
   Do not sweep in unrelated uncommitted working-tree changes you did not author.

----- user request follows -----
'

# ---------------------------------------------------------------------------
# Dependency check

for cmd in curl jq claude; do
    command -v "$cmd" >/dev/null 2>&1 || { echo "error: $cmd is required" >&2; exit 1; }
done

# ---------------------------------------------------------------------------
# Helpers

api() {
    local method="$1" path="$2"; shift 2
    curl -sf -X "$method" \
        -H "Authorization: Bearer $RIVENDELL_BOT_TOKEN" \
        -H "Content-Type: application/json" \
        "$RIVENDELL_URL/api$path" "$@"
}

post_msg() {
    api POST "/channels/$1/messages" --data "$(jq -n --arg c "$2" '{content:$c}')"
}

edit_msg() {
    api PATCH "/messages/$1" --data "$(jq -n --arg c "$2" '{content:$c}')"
}

set_status() {
    api PUT /me/status --data "$(jq -n --arg s "$1" '{status:$s}')" >/dev/null 2>&1 || true
}

set_status_text() {
    api PATCH /me --data "$(jq -n --arg t "$1" '{status_text:$t}')" >/dev/null 2>&1 || true
}

trim_output() {
    local text="$1"
    if [ "${#text}" -gt "$MAX_RESPONSE" ]; then
        printf '%s\n\n…(%d chars total, truncated)' "${text:0:$MAX_RESPONSE}" "${#text}"
    else
        printf '%s' "$text"
    fi
}

# ---------------------------------------------------------------------------
# Startup

echo "rivendell-claude-bridge starting"
echo "  url:      $RIVENDELL_URL"
echo "  channel:  #$CHANNEL_NAME"
echo "  repo:     $REPO_DIR"

ME=$(api GET /me)
BOT_ID=$(jq -r '.id'           <<<"$ME")
BOT_NAME=$(jq -r '.display_name' <<<"$ME")
echo "  bot:      $BOT_NAME (id $BOT_ID)"

# Find the channel the bot is a member of.
CHANNEL_ID=$(api GET /channels \
    | jq -r --arg n "$CHANNEL_NAME" '.[] | select(.name == $n) | .id')
if [ -z "$CHANNEL_ID" ]; then
    cat >&2 <<EOF
error: channel #$CHANNEL_NAME not found.
  Create a private channel named "$CHANNEL_NAME" and add the bot user as a member,
  then restart this bridge.
EOF
    exit 1
fi
echo "  channel id: $CHANNEL_ID"

# Seed the last-seen cursor so we don't replay history on first start.
if [ ! -f "$STATE_FILE" ]; then
    SEED_ID=$(api GET "/channels/$CHANNEL_ID/messages?limit=1" \
        | jq -r 'if length > 0 then .[0].id else 0 end')
    printf '%s' "$SEED_ID" > "$STATE_FILE"
    echo "  seeded at message id $SEED_ID"
fi

echo "polling every ${POLL_INTERVAL}s — ready (DM mode: enabled)"
echo ""

# Signal readiness via the bot's status.
set_status "online"
set_status_text "operational — waiting"

# ---------------------------------------------------------------------------
# Main loop

TMPFILE=$(mktemp)
cleanup() {
    rm -f "$TMPFILE"
    set_status "offline"
    set_status_text "offline"
    echo "bridge stopped"
    exit 0
}
trap cleanup INT TERM

# handle_channel <channel_id> <mode>
# mode = "normal"  → full Claude in $REPO_DIR with BRIDGE_PREAMBLE
# mode = "dm"      → low-effort Claude in /tmp, no write tools, no preamble
handle_channel() {
    local channel_id="$1"
    local mode="$2"
    local state_file

    if [ "$mode" = "dm" ]; then
        state_file="$STATE_DIR/rivendell-bridge-dm-$channel_id"
    else
        state_file="$STATE_FILE"
    fi

    # Seed the cursor on first encounter.
    if [ ! -f "$state_file" ]; then
        local seed_id
        seed_id=$(api GET "/channels/$channel_id/messages?limit=1" 2>/dev/null \
            | jq -r 'if length > 0 then .[0].id else 0 end' 2>/dev/null) || return
        printf '%s' "$seed_id" > "$state_file"
        return
    fi

    local last_id
    last_id=$(cat "$state_file")

    api GET "/channels/$channel_id/messages?limit=20" 2>/dev/null \
        | jq -c \
            --argjson last "$last_id" \
            --argjson bot  "$BOT_ID" \
            '[.[] | select(.id > $last and .user_id != $bot and .deleted_at == null)]
             | reverse | .[]' \
        > "$TMPFILE" 2>/dev/null || return

    while IFS= read -r msg && [ -n "$msg" ]; do
        local msg_id content user_id
        msg_id=$(  jq -r '.id'      <<<"$msg")
        content=$( jq -r '.content' <<<"$msg")
        user_id=$( jq -r '.user_id' <<<"$msg")

        printf '%s' "$msg_id" > "$state_file"

        printf '[%s msg %s user %s] %s\n' "$mode" "$msg_id" "$user_id" "${content:0:100}"

        local work_json work_id
        work_json=$(post_msg "$channel_id" ":working: Working…" 2>/dev/null) || work_json=""
        work_id=$(jq -r '.id // empty' <<<"$work_json")

        local claude_exit=0 claude_out
        if [ "$mode" = "dm" ]; then
            # DM mode: low-effort, no file write tools, run outside the repo.
            claude_out=$(cd /tmp && claude --print --effort low \
                --disallowed-tools "Edit Write Bash" \
                "$content" 2>&1) || claude_exit=$?
        else
            claude_out=$(cd "$REPO_DIR" && claude --print "$BRIDGE_PREAMBLE$content" 2>&1) || claude_exit=$?
        fi

        local trimmed reply
        trimmed=$(trim_output "$claude_out")
        if [ "$claude_exit" -eq 0 ]; then
            reply="✅ Done.

$trimmed"
        else
            reply="❌ Error (exit $claude_exit).

$trimmed"
        fi

        if [ -n "$work_id" ]; then
            edit_msg "$work_id" "$reply" 2>/dev/null \
                || post_msg "$channel_id" "$reply" >/dev/null || true
        else
            post_msg "$channel_id" "$reply" >/dev/null || true
        fi

        local run_time
        run_time=$(TZ=America/Chicago date +%H:%M)
        if [ "$claude_exit" -eq 0 ]; then
            set_status_text "last run: ✅ done at $run_time"
        else
            set_status_text "last run: ❌ error at $run_time"
        fi
        set_status "online"

    done < "$TMPFILE"
}

while true; do
    sleep "$POLL_INTERVAL"

    # Main claude channel — full access.
    handle_channel "$CHANNEL_ID" "normal"

    # DM channels — discover dynamically each cycle, handle in low-effort mode.
    while IFS= read -r dm_id; do
        [ -n "$dm_id" ] && handle_channel "$dm_id" "dm"
    done < <(api GET /channels 2>/dev/null \
        | jq -r '[.[] | select(.is_dm == true)] | .[].id' 2>/dev/null || true)
done
