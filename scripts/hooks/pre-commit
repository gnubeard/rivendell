#!/bin/bash
# pre-commit — run the fast test gate, then auto-bump the patch version on
# develop commits.
#
# The test gate runs the cheap, blocking tier of the suite whenever
# source files are staged, on ANY branch (we want green everywhere): gofmt +
# go vet + the full Go suite when Go is staged, and the web unit tests when
# web/ is staged. The slow Playwright e2e suite is NOT here — it gates `git
# push` from pre-push instead. Doc-only commits skip the gate entirely.
#
# This matters because on develop the post-commit hook deploys the moment a
# source-touching commit lands, so pre-commit is the only point upstream of
# the deploy — see scripts/hooks/post-commit.
#
# Tests run against the WORKING TREE (not the staged tree). For the normal
# solo flow where you commit your whole working tree these are identical; they
# differ only if you stage a partial subset. A stash-the-unstaged approach is
# fragile (pop conflicts) and not worth it here.
#
# Escape hatch: RUN_TESTS=0 git commit … skips the gate (the version bump
# still runs). Use it for deliberate WIP commits — prefer it over --no-verify,
# which also disables the bump.
#
# Install with: make install-hooks
set -euo pipefail

DEPLOY_BRANCH="develop"
VERSION_FILE="internal/config/config.go"
# Two predicates, deliberately different:
#   SRC_RE    — "is there source worth running the test gate for?" Broad: ANY
#               web/ change (incl. e2e specs, playwright config, unit tests)
#               should run the fast web suite. Cheap to over-fire; never wrong.
#   DEPLOY_RE — "does this change actually SHIP?" Narrow allowlist of runtime
#               assets the server serves / the binary embeds, so a test- or
#               tooling-only commit does NOT bump the version or trip the
#               post-commit deploy. Keep in sync with scripts/hooks/post-commit
#               and .github/workflows/release.yml.
SRC_RE='cmd/server|internal/|web/|Dockerfile|go.(mod|sum)'
DEPLOY_RE='cmd/server|internal/|web/static/|web/sw.js|web/index.html|web/manifest.json|Dockerfile|go.(mod|sum)'

# ---------------------------------------------------------------------------
# Test gate — runs on any branch, before the version bump.

staged=$(git diff --cached --name-only --diff-filter=ACM)

if [ "${RUN_TESTS:-1}" != "0" ] && echo "$staged" | grep -qE "$SRC_RE"; then
  go_staged=$(echo "$staged" | grep -E '\.go$|go\.(mod|sum)$' || true)
  web_staged=$(echo "$staged" | grep -E '^web/' || true)

  if [ -n "$go_staged" ]; then
    go_files=$(echo "$go_staged" | grep -E '\.go$' || true)
    if [ -n "$go_files" ]; then
      bad=$(gofmt -l $go_files)
      if [ -n "$bad" ]; then
        echo "pre-commit: gofmt needs to run on:" >&2
        echo "$bad" >&2
        echo "pre-commit: run 'make fmt' and re-stage." >&2
        exit 1
      fi
    fi
    echo "pre-commit: go vet + go test…"
    make vet
    make test-go
  fi

  if [ -n "$web_staged" ]; then
    echo "pre-commit: web unit tests…"
    make test-web
  fi
fi

# ---------------------------------------------------------------------------
# Version bump — develop only.

branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" != "$DEPLOY_BRANCH" ]; then
  exit 0
fi

# Only enforce version bump when a shipping (runtime) source file is staged —
# DEPLOY_RE, not SRC_RE: a test/tooling-only commit must not bump or deploy.
if ! echo "$staged" | grep -qE "$DEPLOY_RE"; then
  exit 0
fi

# Extract Version constant value from a stream of config.go content.
extract_version() {
  sed -n 's/.*const Version = "\([^"]*\)".*/\1/p'
}

# Version in the last commit (empty on first commit or if file didn't exist yet).
head_version=$(git show HEAD:"$VERSION_FILE" 2>/dev/null | extract_version || true)

# Version staged for this commit.
staged_version=$(git show :"$VERSION_FILE" 2>/dev/null | extract_version || true)

if [ -z "$staged_version" ]; then
  exit 0
fi

if [ "$head_version" = "$staged_version" ]; then
  IFS='.' read -r major minor patch <<< "$staged_version"
  new_version="$major.$minor.$((patch + 1))"
  sed -i "s/const Version = \"$staged_version\"/const Version = \"$new_version\"/" "$VERSION_FILE"
  git add "$VERSION_FILE"
  echo "pre-commit: version auto-bumped $staged_version → $new_version"
fi
