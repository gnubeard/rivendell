#!/bin/bash
# pre-push — run the Playwright e2e suite before a push that ships runtime
# code, gating the image release on main.
#
# The e2e suite takes minutes, so it does NOT belong in pre-commit (that would
# just train --no-verify). Pushes are rare, so the latency lands where it's
# affordable. We only run it when the push range touches runtime source
# (cmd/server, internal/, web/) — a docs/tooling-only push skips it.
#
# Uses the e2e plumbing already wired in Makefile + the git-ignored
# Makefile.local (chat_e2e DB, browsers installed). Chromium only; the WebKit
# smoke stays opt-in via E2E_WEBKIT and is not part of this gate.
#
# git feeds pre-push these lines on stdin:
#   <local ref> <local sha> <remote ref> <remote sha>
#
# Escape hatch: RUN_E2E=0 git push … skips the gate.
#
# Install with: make install-hooks
set -euo pipefail

[ "${RUN_E2E:-1}" = "0" ] && exit 0

ZERO="0000000000000000000000000000000000000000"
SRC_RE='cmd/server|internal/|web/'

run_e2e=0
while read -r local_ref local_sha remote_ref remote_sha; do
  # Branch deletion (local side all-zero) — nothing to test.
  [ "$local_sha" = "$ZERO" ] && continue

  if [ "$remote_sha" = "$ZERO" ]; then
    # New branch on the remote: no cheap range to diff. Be safe and run e2e.
    run_e2e=1
  elif git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null \
       | grep -qE "$SRC_RE"; then
    run_e2e=1
  fi
done

if [ "$run_e2e" = "1" ]; then
  echo "pre-push: running e2e (make test-e2e)…"
  make test-e2e
fi
