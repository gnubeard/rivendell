# Snug configuration (copy to .env and adjust). All variables are optional and
# fall back to the defaults shown here, except SNUG_DATABASE_URL in production.

# Listen address.
SNUG_ADDR=:8080

# Postgres connection string.
SNUG_DATABASE_URL=postgres://chat:chat_dev_pw@localhost:5432/chat?sslmode=disable

# Where the static web client lives.
SNUG_WEB_DIR=./web

# Base URL used to build magic links the admin copies (no trailing slash).
SNUG_PUBLIC_URL=http://localhost:8080

# Set to true when serving over HTTPS so the session cookie gets the Secure flag.
SNUG_COOKIE_SECURE=false

# Session and magic-link lifetimes (Go duration syntax: 720h, 30m, etc.).
SNUG_SESSION_TTL=720h
SNUG_MAGIC_LINK_TTL=48h

# Limits.
SNUG_MAX_MESSAGE_BYTES=8192
SNUG_MAX_AVATAR_BYTES=1048576

# Display name of this instance, shown as the page title and brand. "snug" is the
# software; name your instance whatever you like (e.g. "rivendell").
SNUG_INSTANCE_NAME=snug

# Username of the admin auto-created on first boot (when no admins exist yet).
SNUG_BOOTSTRAP_ADMIN=admin
