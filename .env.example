# Rivendell configuration (copy to .env and adjust). All variables are optional and
# fall back to the defaults shown here, except RIVENDELL_DATABASE_URL in production.

# Listen address.
RIVENDELL_ADDR=:8080

# Postgres connection string.
RIVENDELL_DATABASE_URL=postgres://chat:chat_dev_pw@localhost:5432/chat?sslmode=disable

# Where the static web client lives.
RIVENDELL_WEB_DIR=./web

# Base URL used to build magic links the admin copies (no trailing slash).
RIVENDELL_PUBLIC_URL=http://localhost:8080

# Set to true when serving over HTTPS so the session cookie gets the Secure flag.
RIVENDELL_COOKIE_SECURE=false

# Session and magic-link lifetimes (Go duration syntax: 720h, 30m, etc.).
RIVENDELL_SESSION_TTL=720h
RIVENDELL_MAGIC_LINK_TTL=72h

# Limits.
RIVENDELL_MAX_MESSAGE_BYTES=8000
RIVENDELL_MAX_AVATAR_BYTES=524288

# Display name of this instance, shown as the page title and brand. "rivendell" is the
# software; name your instance whatever you like (e.g. "rivendell").
RIVENDELL_INSTANCE_NAME=rivendell

# Username of the admin auto-created on first boot (when no admins exist yet).
RIVENDELL_BOOTSTRAP_ADMIN=admin

# Web Push (offline notifications). The VAPID keypair is generated on first boot
# and persisted in the database, so nothing is required here. This is only the
# `sub` claim sent to the push service (a mailto: or https URL it can use to
# contact the operator); it defaults to RIVENDELL_PUBLIC_URL if unset.
# RIVENDELL_VAPID_SUBJECT=mailto:admin@example.com

# WebRTC debug telemetry. When true, enables POST /api/debug/telemetry and tells
# every client (via GET /api/instance) to capture getStats() snapshots + call
# lifecycle events and ship them here, logged to stdout as `rtc-telem.*` logfmt
# lines. A diagnostic switch for video-call issues — leave off in normal operation.
# RIVENDELL_DEBUG_TELEMETRY=true
