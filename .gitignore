# Build artifacts
/bin/
rivendell

# Environment
.env
.env.local

# Per-host Make overrides (e2e DB reset path, container names, ports) — untracked
# by design; see Makefile.local.example.
Makefile.local

# Per-host setup helpers (e.g. the WebKit e2e native-stack provisioning) — the
# tracked recipe lives in docs/webkit-e2e.md; the executable copy is host-local.
scripts/*.local.sh

# sensitive credentials
.creds

# Node (frontend test runner + dev-only Playwright e2e tooling)
node_modules/
web/package-lock.json

# Playwright e2e artifacts (suite under web/e2e)
web/test-results/
test-results/
web/playwright-report/
web/e2e/.e2e-state.json
web/e2e/server.log
web/blobs

# OS / editor cruft
.DS_Store
*.swp
